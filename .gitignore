# =========================
# Python Standard Ignores
# =========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# =========================
# Virtual Environments
# =========================
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# =========================
# IDEs and OS Files
# =========================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# =========================
# Project Specific Files
# =========================
# Ignore local database files to prevent committing sensitive/mock data
*.csv
*.json
# (Optional) If you have a specific JSON config file you DO want to track, 
# you can un-ignore it by removing the '#' below:
# !config.json
